# Opcjonalnie: skopiuj do backend/.env.local tylko gdy chcesz nadpisać DATABASE_URL.
# Przy domyślnym backend/.env + docker-compose z repozytorium **nie jest potrzebne** —
# Compose tworzy użytkownika app / bazę app / hasło jak w .env.

DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=16&charset=utf8"
